<stack class="container" @swipe="onswipe">
    <div class="container">
        <text class="lock-settings-title" style="letter-spacing : {{ letter_space }};">{{ lock_tips }}</text>
        <div class="number-container">
            <input type="button" @click="input('1')" class="input-number input-left" value="1"></input>
            <input type="button" @click="input('2')" class="input-number" value="2"></input>
            <input type="button" @click="input('3')" class="input-number" value="3"></input>
            <input type="button" @click="input('4')" class="input-number input-left" value="4"></input>
            <input type="button" @click="input('5')" class="input-number" value="5"></input>
            <input type="button" @click="input('6')" class="input-number" value="6"></input>
            <input type="button" @click="input('7')" class="input-number input-left" value="7"></input>
            <input type="button" @click="input('8')" class="input-number" value="8"></input>
            <input type="button" @click="input('9')" class="input-number" value="9"></input>
            <input type="button" @click="input('0')" class="input-number input-left" value="0"></input>
        </div>
    </div>
    <input type="button" class="delete-button" @click="delete"></input>
</stack>